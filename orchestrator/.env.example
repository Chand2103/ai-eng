# AWS Transcribe (required)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1

# Backend selection: "vast" (default) or "openrouter"
BACKEND_MODE=vast

# Vast.ai backend (default)
VAST_SERVER_URL=ws://localhost:10100/ws/orchestrator

# OpenRouter backend (requires OPENROUTER_API_KEY)
OPENROUTER_API_KEY=
OPENROUTER_LLM_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_TTS_MODEL=x-ai/grok-voice-tts-1.0
OPENROUTER_TTS_VOICE=Eve
OPENROUTER_TTS_FORMAT=pcm      # pcm or mp3; pcm is wrapped in WAV automatically
OPENROUTER_TTS_SAMPLE_RATE=24000  # sample rate for PCM (used only when format=pcm)

# Orchestrator server
ORCHESTRATOR_PORT=8001
