# AWS Transcribe (required for all modes)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1

# Backend selection: "vast" | "openrouter" | "vast_serverless_tts"
BACKEND_MODE=vast

# Vast.ai backend (BACKEND_MODE=vast, the default)
VAST_SERVER_URL=ws://localhost:10100/ws/orchestrator

# OpenRouter LLM (used by BACKEND_MODE=openrouter and BACKEND_MODE=vast_serverless_tts)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# OpenRouter TTS (used only when BACKEND_MODE=openrouter)
OPENROUTER_TTS_MODEL=x-ai/grok-voice-tts-1.0
OPENROUTER_TTS_VOICE=Eve
OPENROUTER_TTS_SAMPLE_RATE=24000  # sample rate for PCM → WAV conversion

# Vast serverless TTS (used only when BACKEND_MODE=vast_serverless_tts)
VAST_SERVERLESS_ENDPOINT_NAME=
VAST_API_KEY=
TTS_VOICE_ID=1                # selects which built-in reference voice to use (1 = Alice, …)

# Orchestrator server
ORCHESTRATOR_PORT=8001
